---
interface Props {
  title: string;
  description: string;
  href: string;
  date: string;
  category: string;
  image?: string;
}
const { title, description, href, date, category, image } = Astro.props;
---

<article class="bg-white border border-[var(--color-border)] rounded-lg overflow-hidden hover:border-[var(--color-text-muted)] transition-colors duration-200">
  <a href={href} class="block cursor-pointer">
    {image && (
      <img src={image} alt={title} class="w-full h-40 object-cover" width="400" height="160" loading="lazy" />
    )}
    <div class="p-5">
      <div class="flex items-center gap-2 text-xs mb-3">
        <span class="font-medium text-[var(--color-accent)]">{category}</span>
        <span class="text-[var(--color-border)]" aria-hidden="true">/</span>
        <time datetime={date} class="text-[var(--color-text-muted)]">
          {new Date(date).toLocaleDateString('fr-FR', { year: 'numeric', month: 'short', day: 'numeric' })}
        </time>
      </div>
      <h3 class="text-lg font-bold text-[var(--color-text)] mb-2 line-clamp-2 leading-snug">
        {title}
      </h3>
      <p class="text-sm text-[var(--color-text-muted)] line-clamp-3 leading-relaxed mb-4">
        {description}
      </p>
      <span class="inline-flex items-center gap-1 text-sm font-medium text-[var(--color-accent)]">
        Lire
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </span>
    </div>
  </a>
</article>
