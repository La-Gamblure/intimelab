---
import type { Product } from '../data/products';
import CTAButton from './CTAButton.astro';

interface Props {
  product: Product;
  rank: number;
  badge?: string;
}

const { product, rank, badge } = Astro.props;
const reviewUrl = `/${product.category}/avis-${product.slug}/`;
---

<div class="rounded-2xl border border-[var(--color-border)] bg-white p-5 hover:shadow-lg transition-shadow relative">
  <div class="absolute -top-3 -left-2 w-10 h-10 rounded-full bg-[var(--color-accent)] text-white font-bold flex items-center justify-center text-lg shadow-md">
    {rank}
  </div>

  {badge && (
    <div class="absolute -top-3 right-3">
      <span class="inline-block px-3 py-1 rounded-full bg-[var(--color-warm)] text-white text-xs font-bold shadow-sm">
        {badge}
      </span>
    </div>
  )}

  <div class="flex flex-col sm:flex-row gap-5 mt-3">
    <div class="w-full sm:w-32 h-32 rounded-xl overflow-hidden shrink-0">
      {product.image ? (
        <img
          src={product.image}
          alt={product.name}
          class="w-full h-full object-cover"
          loading="lazy"
          width="128"
          height="128"
        />
      ) : (
        <div class="w-full h-full bg-gradient-to-br from-[var(--color-accent)] to-[var(--color-rose)] flex items-center justify-center">
          <span class="text-white/80 text-3xl font-bold">{product.brand[0]}</span>
        </div>
      )}
    </div>

    <div class="flex-1 min-w-0">
      <span class="text-xs font-medium text-[var(--color-text-muted)] uppercase tracking-wide">{product.brand}</span>
      <h3 class="font-bold text-[var(--color-text)] text-xl mb-1">{product.name}</h3>
      <p class="text-sm text-[var(--color-text-secondary)] mb-2">{product.tagline}</p>

      <div class="flex items-center gap-3 mb-4">
        <span class="text-lg font-bold text-[var(--color-accent)]">{product.rating.toFixed(1)}/10</span>
        <span class="text-sm text-[var(--color-text-muted)]">{product.priceRange}</span>
      </div>

      <div class="flex gap-3 flex-wrap">
        <CTAButton product={product} />
        <a
          href={reviewUrl}
          class="inline-block px-5 py-2.5 rounded-full border border-[var(--color-accent)] text-[var(--color-accent)] font-semibold text-sm hover:bg-[var(--color-accent-light)] transition-colors cursor-pointer"
        >
          Lire notre avis
        </a>
      </div>
    </div>
  </div>
</div>
