---
interface Props {
  ratings: { label: string; score: number }[];
  overall: number;
}

const { ratings, overall } = Astro.props;
---

<div class="rounded-xl border border-[var(--color-border)] bg-white p-5">
  <div class="flex items-center justify-between mb-4">
    <h4 class="font-bold text-[var(--color-text)]">Notes detaillees</h4>
    <div class="flex items-center gap-2">
      <span class="text-2xl font-bold text-[var(--color-accent)]">{overall.toFixed(1)}</span>
      <span class="text-sm text-[var(--color-text-muted)]">/ 10</span>
    </div>
  </div>

  <div class="space-y-3">
    {ratings.map(r => (
      <div>
        <div class="flex items-center justify-between mb-1">
          <span class="text-sm text-[var(--color-text-secondary)]">{r.label}</span>
          <span class="text-sm font-semibold text-[var(--color-text)]">{r.score.toFixed(1)}</span>
        </div>
        <div class="h-2 bg-[var(--color-bg-subtle)] rounded-full overflow-hidden">
          <div
            class="h-full rounded-full bg-gradient-to-r from-[var(--color-accent)] to-[var(--color-accent-hover)]"
            style={`width: ${(r.score / 10) * 100}%`}
          />
        </div>
      </div>
    ))}
  </div>
</div>
