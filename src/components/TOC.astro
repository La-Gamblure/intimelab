---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}
const { headings } = Astro.props;
const tocItems = headings.filter(h => h.depth === 2 || h.depth === 3);
---

{tocItems.length > 0 && (
  <details open class="border border-[var(--color-border)] rounded-lg mb-10 group">
    <summary class="flex items-center justify-between p-5 cursor-pointer select-none text-xs font-semibold text-[var(--color-text)] uppercase tracking-widest hover:bg-[var(--color-bg-subtle)] transition-colors rounded-lg">
      Sommaire
      <svg class="w-4 h-4 text-[var(--color-text-muted)] transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
      </svg>
    </summary>
    <ol class="px-5 pb-5 space-y-0.5 text-sm" role="list">
      {tocItems.map(item => (
        <li class={item.depth === 3 ? 'ml-4' : ''}>
          <a
            href={`#${item.slug}`}
            class:list={[
              "block py-1 transition-colors duration-200 hover:text-[var(--color-accent)] cursor-pointer",
              item.depth === 2 ? "text-[var(--color-text-secondary)] font-medium" : "text-[var(--color-text-muted)]"
            ]}
          >
            {item.text}
          </a>
        </li>
      ))}
    </ol>
  </details>
)}
