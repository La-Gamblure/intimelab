---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('connectes'))
  .sort((a, b) => new Date(b.data.date_published).getTime() - new Date(a.data.date_published).getTime());
---

<BaseLayout
  title="Sextoys connectes — Guides educatifs | IntimeLab"
  description="Guides sur les sextoys connectes, la longue distance et les applis pour couples. Contenu independant et comparatifs detailles."
>
  <div class="max-w-6xl 2xl:max-w-7xl mx-auto px-4 sm:px-6 py-10">
    <nav class="text-sm text-[var(--color-text-muted)] mb-8" aria-label="Fil d'Ariane">
      <ol class="flex items-center gap-1.5">
        <li><a href="/" class="hover:text-[var(--color-text)] transition-colors cursor-pointer">Accueil</a></li>
        <li aria-hidden="true">/</li>
        <li class="text-[var(--color-text-secondary)]">Sextoys connectes</li>
      </ol>
    </nav>

    <h1 class="text-3xl sm:text-4xl font-bold text-[var(--color-text)] mb-4">Sextoys connectes</h1>
    <p class="text-lg text-[var(--color-text-secondary)] mb-10 max-w-2xl">
      Vibromasseurs connectes, sextoys longue distance, applis couple : nos guides pour maintenir l'intimite, meme a distance.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {articles.map(article => (
        <ArticleCard
          title={article.data.h1}
          description={article.data.meta_description}
          href={`/connectes/${article.id}/`}
          date={article.data.date_published}
          category="Connectes"
        />
      ))}
    </div>

    <section class="mt-16 pt-10 border-t border-[var(--color-border)]">
      <h2 class="text-2xl font-bold text-[var(--color-text)] mb-4">Nos recommandations</h2>
      <p class="text-[var(--color-text-secondary)] mb-6 max-w-2xl">
        Decouvrez notre selection de sextoys connectes testes et evalues par notre redaction.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/connectes/meilleur-sextoy-connecte/" class="inline-block px-5 py-2.5 rounded-full bg-[var(--color-accent)] text-white font-semibold text-sm hover:bg-[var(--color-accent-hover)] transition-colors cursor-pointer">
          Comparatif des meilleurs sextoys connectes →
        </a>
        <a href="/recommandations/" class="inline-block px-5 py-2.5 rounded-full border border-[var(--color-accent)] text-[var(--color-accent)] font-semibold text-sm hover:bg-[var(--color-accent-light)] transition-colors cursor-pointer">
          Toutes nos recommandations
        </a>
      </div>
    </section>
  </div>
</BaseLayout>
