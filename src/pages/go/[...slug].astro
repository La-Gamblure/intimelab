---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { products, type Product } from '../../data/products';

export function getStaticPaths() {
  return products.map(p => ({
    params: { slug: p.slug },
    props: { product: p },
  }));
}

const { slug } = Astro.params;
const { product } = Astro.props as { product: Product };
const targetUrl = product.affiliateUrl;
const hasRealUrl = targetUrl !== '#';
---

<BaseLayout
  title={`Redirection — ${product.name} | IntimeLab`}
  description={`Lien partenaire vers ${product.name}`}
  noindex={true}
  redirectUrl={hasRealUrl ? targetUrl : undefined}
>
  <div class="min-h-[60vh] flex items-center justify-center px-4">
    <div class="text-center max-w-md">
      {hasRealUrl ? (
        <p class="text-[var(--color-text-secondary)] mb-4">
          Redirection vers <strong class="text-[var(--color-text)]">{product.name}</strong>…
        </p>
        <p class="text-sm text-[var(--color-text-muted)]">
          Si rien ne se passe, <a href={targetUrl} class="text-[var(--color-accent)] underline" rel="noopener sponsored">cliquez ici</a>.
        </p>
      ) : (
        <>
          <p class="text-[var(--color-text)] font-semibold text-lg mb-2">
            Lien bientot disponible
          </p>
          <p class="text-[var(--color-text-secondary)] mb-6">
            Le lien partenaire pour <strong>{product.name}</strong> sera actif prochainement.
          </p>
          <a href="/" class="inline-block px-6 py-2.5 rounded-full bg-[var(--color-accent)] text-white font-semibold hover:bg-[var(--color-accent-hover)] transition-colors">
            Retour a l'accueil
          </a>
        </>
      )}
    </div>
  </div>

  {hasRealUrl && (
    <script define:vars={{ targetUrl }}>
      window.location.replace(targetUrl);
    </script>
  )}
</BaseLayout>
