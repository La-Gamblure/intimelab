---
import AffiliateLayout from '../../layouts/AffiliateLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getByCategory } from '../../data/products';

const prostateProducts = getByCategory('prostate');
const connectesProducts = getByCategory('connectes');

const jsonld = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Nos recommandations produits — IntimeLab",
  "description": "Selection de produits intimes testes et recommandes par la redaction IntimeLab.",
  "numberOfItems": prostateProducts.length + connectesProducts.length,
  "itemListElement": [...prostateProducts, ...connectesProducts].map((p, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": p.name,
    "url": `https://intimelab.fr/${p.category}/avis-${p.slug}/`,
  })),
});

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Recommandations' },
];
---

<AffiliateLayout
  title="Nos recommandations produits intimes | IntimeLab"
  description="Selection de masseurs prostatiques et sextoys connectes testes et recommandes. Comparatifs independants, avis detailles et guides d'achat."
  breadcrumbs={breadcrumbs}
  jsonld={jsonld}
>
  <header class="mb-12 rounded-2xl bg-gradient-to-br from-[#1A1A2E] to-[var(--color-accent)] p-8 sm:p-12 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <svg class="w-full h-full" viewBox="0 0 800 200" fill="none"><circle cx="100" cy="100" r="80" stroke="white" stroke-width="0.5" /><circle cx="700" cy="80" r="120" stroke="white" stroke-width="0.5" /></svg>
    </div>
    <div class="relative">
      <p class="text-sm font-semibold uppercase tracking-widest text-[var(--color-warm)] mb-3">Selection independante</p>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4">Nos recommandations</h1>
      <p class="text-lg text-white/70 max-w-2xl">
        Produits intimes testes et evalues par notre redaction. Criteres objectifs : confort, puissance, connectivite et rapport qualite/prix.
      </p>
    </div>
  </header>

  <!-- Prostate -->
  <section class="mb-16">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-[var(--color-text)]">Masseurs prostatiques</h2>
      <a href="/prostate/meilleur-masseur-prostatique/" class="text-sm font-semibold text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors cursor-pointer">
        Voir le comparatif →
      </a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {prostateProducts.map(product => (
        <ProductCard product={product} />
      ))}
    </div>
  </section>

  <!-- Connectes -->
  <section>
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-[var(--color-text)]">Sextoys connectes</h2>
      <a href="/connectes/meilleur-sextoy-connecte/" class="text-sm font-semibold text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors cursor-pointer">
        Voir le comparatif →
      </a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {connectesProducts.map(product => (
        <ProductCard product={product} />
      ))}
    </div>
  </section>
</AffiliateLayout>
